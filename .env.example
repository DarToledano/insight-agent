# PostgreSQL
POSTGRES_USER=insight
POSTGRES_PASSWORD=insight
POSTGRES_DB=insightagent
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg://insight:insight@db:5432/insightagent
DEBUG=true

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# OpenAI — get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Metadata Engine
METADATA_LOW_CARDINALITY_THRESHOLD=20

# Insight generation — max rows sent to LLM for summarization
INSIGHT_MAX_ROWS=50
